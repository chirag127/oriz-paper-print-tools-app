---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Graph Paper Generator — Oriz Print" description="Generate squared, dotted, lined, or hexagonal graph paper. Pick size and density, download as PDF. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Graph Paper Generator</h1>
    <p class="status mono ready">ready</p>
    <p class="lede">Select grid type, paper size, and density — then download a print-ready PDF.</p>

    <div class="controls">
      <div class="ctrl-row">
        <label>Grid type
          <select id="grid-type">
            <option value="squared">Squared</option>
            <option value="dotted">Dotted</option>
            <option value="lined">Lined (horizontal)</option>
            <option value="hexagonal">Hexagonal</option>
          </select>
        </label>
        <label>Paper size
          <select id="paper-size">
            <option value="a4">A4 (210 × 297 mm)</option>
            <option value="letter">US Letter (215.9 × 279.4 mm)</option>
            <option value="a5">A5 (148 × 210 mm)</option>
          </select>
        </label>
        <label>Spacing (mm)
          <input id="spacing" type="number" min="3" max="25" value="5" />
        </label>
        <label>Line color
          <input id="line-color" type="color" value="#aaaaaa" style="width:3rem;height:2rem;padding:0.1rem;" />
        </label>
      </div>
      <div class="ctrl-row">
        <label>Margin (mm) <input id="margin" type="number" min="5" max="30" value="15" /></label>
        <label><input id="show-title" type="checkbox" checked /> Show title on page</label>
      </div>
    </div>

    <div class="preview-wrap">
      <canvas id="graph-canvas"></canvas>
    </div>

    <div class="actions">
      <button id="download-pdf" class="btn btn-primary">Download PDF</button>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
  .ctrl-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end; }
  label { font-size: 0.875rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.25rem; }
  label input[type="checkbox"] { width: auto; }
  select, input[type="number"] {
    padding: 0.4rem 0.6rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
  .btn {
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--rule);
    background: var(--paper-2);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
    letter-spacing: 0.04em;
  }
  .btn:hover { background: var(--ink); color: var(--paper); }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn-primary:hover { opacity: 0.85; background: var(--accent); color: #fff; }
  .preview-wrap { border: 1px solid var(--rule); display: inline-block; max-width: 100%; overflow: auto; background: white; margin-bottom: 1rem; }
  canvas { display: block; max-width: 100%; }
  .actions { margin-top: 0.5rem; }
</style>

<script>
  import { jsPDF } from 'jspdf';

  const gridTypeEl = document.getElementById('grid-type') as HTMLSelectElement;
  const paperSizeEl = document.getElementById('paper-size') as HTMLSelectElement;
  const spacingEl = document.getElementById('spacing') as HTMLInputElement;
  const lineColorEl = document.getElementById('line-color') as HTMLInputElement;
  const marginEl = document.getElementById('margin') as HTMLInputElement;
  const showTitleEl = document.getElementById('show-title') as HTMLInputElement;
  const canvas = document.getElementById('graph-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  const pageSizes: Record<string, [number, number]> = {
    a4: [210, 297],
    letter: [215.9, 279.4],
    a5: [148, 210],
  };

  const PREVIEW_SCALE = 2; // px per mm

  function hexColor(hex: string): [number, number, number] {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return [r, g, b];
  }

  function drawGrid(c: CanvasRenderingContext2D, pxPerMm: number, pw: number, ph: number) {
    const type = gridTypeEl.value;
    const spacing = parseFloat(spacingEl.value) || 5;
    const margin = parseFloat(marginEl.value) || 15;
    const color = lineColorEl.value;
    const showTitle = showTitleEl.checked;

    const W = pw * pxPerMm;
    const H = ph * pxPerMm;
    c.fillStyle = '#ffffff';
    c.fillRect(0, 0, W, H);

    const m = margin * pxPerMm;
    const s = spacing * pxPerMm;

    c.strokeStyle = color;
    c.fillStyle = color;
    c.lineWidth = 0.5;

    if (type === 'squared') {
      for (let x = m; x <= W - m; x += s) {
        c.beginPath(); c.moveTo(x, m); c.lineTo(x, H - m); c.stroke();
      }
      for (let y = m; y <= H - m; y += s) {
        c.beginPath(); c.moveTo(m, y); c.lineTo(W - m, y); c.stroke();
      }
    } else if (type === 'dotted') {
      const r = Math.max(1, pxPerMm * 0.4);
      for (let x = m; x <= W - m; x += s) {
        for (let y = m; y <= H - m; y += s) {
          c.beginPath(); c.arc(x, y, r, 0, Math.PI * 2); c.fill();
        }
      }
    } else if (type === 'lined') {
      for (let y = m; y <= H - m; y += s) {
        c.beginPath(); c.moveTo(m, y); c.lineTo(W - m, y); c.stroke();
      }
    } else if (type === 'hexagonal') {
      const hexR = s * 0.577;
      const hexW = hexR * 2;
      const hexH = s;
      const horizSpacing = hexW * 0.75;

      let col = 0;
      for (let x = m; x < W - m; x += horizSpacing, col++) {
        const yOffset = col % 2 === 0 ? 0 : hexH / 2;
        for (let y = m + yOffset; y < H - m; y += hexH) {
          c.beginPath();
          for (let i = 0; i < 6; i++) {
            const angle = (Math.PI / 3) * i - Math.PI / 6;
            const hx = x + hexR * Math.cos(angle);
            const hy = y + hexR * Math.sin(angle);
            i === 0 ? c.moveTo(hx, hy) : c.lineTo(hx, hy);
          }
          c.closePath();
          c.stroke();
        }
      }
    }

    if (showTitle) {
      c.fillStyle = '#999999';
      c.font = `${9 * pxPerMm}px serif`;
      c.fillText(`${type} · ${spacing}mm · ${pw}×${ph}mm`, m, H - m * 0.4);
    }
  }

  function render() {
    const [pw, ph] = pageSizes[paperSizeEl.value] || pageSizes.a4;
    canvas.width = pw * PREVIEW_SCALE;
    canvas.height = ph * PREVIEW_SCALE;
    drawGrid(ctx, PREVIEW_SCALE, pw, ph);
  }

  [gridTypeEl, paperSizeEl, spacingEl, lineColorEl, marginEl, showTitleEl].forEach(el => {
    el.addEventListener('change', render);
    el.addEventListener('input', render);
  });

  document.getElementById('download-pdf')!.addEventListener('click', () => {
    const [pw, ph] = pageSizes[paperSizeEl.value] || pageSizes.a4;
    const PDF_SCALE = 5; // higher res for PDF
    const offscreen = document.createElement('canvas');
    offscreen.width = pw * PDF_SCALE;
    offscreen.height = ph * PDF_SCALE;
    const octx = offscreen.getContext('2d')!;
    drawGrid(octx, PDF_SCALE, pw, ph);

    const imgData = offscreen.toDataURL('image/png');
    const doc = new jsPDF({ unit: 'mm', format: [pw, ph], orientation: ph > pw ? 'portrait' : 'landscape' });
    doc.addImage(imgData, 'PNG', 0, 0, pw, ph);
    doc.save(`graph-paper-${gridTypeEl.value}-${paperSizeEl.value}.pdf`);
  });

  render();
</script>
